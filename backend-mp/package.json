{
  "name": "sisgad5-backend-mp",
  "version": "1.0.0",
  "description": "Microservicio de Mesa de Prueba para SISGAD5",
  "main": "src/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "generate:models": "node scripts/generate-models.js",
    "generate:cruds": "node scripts/generate-cruds.js",
    "db:sync": "node -e \"require('./src/models').syncModels()\"",
    "swagger:export": "node -e \"const swagger=require('./src/config/swagger');const fs=require('fs');fs.mkdirSync('docs',{recursive:true});fs.writeFileSync('docs/swagger.json',JSON.stringify(swagger,null,2));console.log('✅ Swagger exportado a docs/swagger.json')\""
  },
  "keywords": [
    "express",
    "postgresql",
    "sequelize"
  ],
  "author": "Yaisel Botet Cesar",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemon": "^3.1.10",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  }
}
